# ai-reports environment

# Browser-side: where to fetch all data assets from (JSON + parquet).
# Leave unset to serve from local public/data (Vite dev).
VITE_DATA_BASE_URL=https://budget-assets.bettergov.ph

# Build-time only: R2 upload credentials for scripts/upload-to-r2.ts
# Create at: Cloudflare dashboard → BetterGov → R2 → Manage API tokens
# Scope: Object Read & Write on the budget bucket.
R2_ACCOUNT_ID=cd41784b73cc20f93b3137292f818ff6
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=budget
